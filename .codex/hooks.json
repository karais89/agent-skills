{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/hooks/codex-session-start.js\"",
            "commandWindows": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"node (Join-Path (git rev-parse --show-toplevel) 'hooks/codex-session-start.js')\"",
            "statusMessage": "Loading agent-skills Codex context",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
